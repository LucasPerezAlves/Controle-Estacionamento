@model IEnumerable<RegistroEstacionamento>

@{
    ViewData["Title"] = "Estacionamento";
    var abertos = Model.Where(r => r.EstaAberto).ToList();
    var totalVagas = Math.Max(12, ((abertos.Count + 3) / 4) * 4);
}

<div class="mb-8">
    <h1 class="text-2xl font-bold tracking-tight">Estacionamento</h1>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">Registre entradas, acompanhe as vagas em tempo real e feche a saída dos veículos.</p>
</div>

@if (TempData["Erro"] is string erro)
{
    <div class="mb-6 rounded-lg border border-red-200 dark:border-red-900 bg-red-50 dark:bg-red-950/30 text-red-700 dark:text-red-400 text-sm px-4 py-3">
        @erro
    </div>
}

<section class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5 shadow-sm mb-10">
    <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 mb-3">Marcar Entrada</h2>
    <form asp-action="MarcarEntrada" method="post" class="flex flex-col sm:flex-row gap-3">
        <input type="text" name="placa" placeholder="ABC1D23" required
               class="placa uppercase flex-1 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 px-3 py-2 text-sm font-semibold tracking-widest focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition" />
        <button type="submit"
                class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 active:scale-95 text-white text-sm font-medium px-5 py-2 transition-all duration-150">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Marcar Entrada
        </button>
    </form>
</section>

<section class="mb-10">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">Estacionamento agora</h2>
        <span class="text-sm text-zinc-500 dark:text-zinc-400">@abertos.Count veículo(s) estacionado(s)</span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
        @for (var i = 0; i < totalVagas; i++)
        {
            if (i < abertos.Count)
            {
                var registro = abertos[i];
                <div class="animar-entrada group relative rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
                     style="animation-delay: @(i * 40)ms">
                    <svg class="w-8 h-8 mx-auto text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 17h8m-9-4h10l1.5-4.5a1 1 0 0 0-.9-1.3H8.4a1 1 0 0 0-.9 1.3L9 13Zm-3 4a1 1 0 1 1-2 0 1 1 0 0 1 2 0Zm14 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0Z" />
                    </svg>
                    <div class="flex justify-center mt-2">
                        <span class="placa inline-flex items-stretch overflow-hidden rounded border-2 border-zinc-800 text-xs font-bold">
                            <span class="bg-blue-600 text-white px-1 flex items-center text-[9px]">BR</span>
                            <span class="bg-zinc-50 text-zinc-900 px-1.5 py-0.5">@registro.Placa</span>
                        </span>
                    </div>
                    <p class="tempo-estacionado text-center text-xs text-zinc-500 dark:text-zinc-400 mt-2" data-entrada="@registro.DataHoraEntrada.ToString("o")">--</p>
                    <form asp-action="MarcarSaida" method="post" class="mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                        <input type="hidden" name="placa" value="@registro.Placa" />
                        <button type="submit" class="w-full text-xs font-medium bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900 rounded-md py-1 hover:opacity-90 transition">
                            Marcar Saída
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="rounded-xl border-2 border-dashed border-zinc-200 dark:border-zinc-800 flex items-center justify-center min-h-[112px]">
                    <span class="text-xs text-zinc-400 dark:text-zinc-600">Vaga livre</span>
                </div>
            }
        }
    </div>
</section>

<section>
    <h2 class="text-lg font-semibold mb-4">Histórico</h2>
    <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-zinc-200 dark:border-zinc-800 text-left text-xs uppercase tracking-wide text-zinc-500 dark:text-zinc-400">
                        <th class="px-4 py-3 font-medium">Placa</th>
                        <th class="px-4 py-3 font-medium">Entrada</th>
                        <th class="px-4 py-3 font-medium">Saída</th>
                        <th class="px-4 py-3 font-medium text-right">Valor Pago</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100 dark:divide-zinc-800">
                    @foreach (var registro in Model)
                    {
                        <tr class="hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors">
                            <td class="px-4 py-3 font-semibold placa">@registro.Placa</td>
                            <td class="px-4 py-3 text-zinc-600 dark:text-zinc-400">@registro.DataHoraEntrada.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-3">
                                @if (registro.EstaAberto)
                                {
                                    <span class="inline-flex items-center rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 text-xs font-medium px-2 py-0.5">Em aberto</span>
                                }
                                else
                                {
                                    <span class="text-zinc-600 dark:text-zinc-400">@registro.DataHoraSaida?.ToString("dd/MM/yyyy HH:mm")</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-right font-medium">
                                @(registro.ValorPago?.ToString("C", new CultureInfo("pt-BR")) ?? "-")
                            </td>
                            <td class="px-4 py-3 text-right">
                                @if (registro.EstaAberto)
                                {
                                    <form asp-action="MarcarSaida" method="post" class="inline">
                                        <input type="hidden" name="placa" value="@registro.Placa" />
                                        <button type="submit" class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline">Marcar Saída</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
