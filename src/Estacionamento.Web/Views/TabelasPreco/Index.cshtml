@model IEnumerable<TabelaPreco>

@{
    ViewData["Title"] = "Tabelas de Preço";
}

<div class="mb-8">
    <h1 class="text-2xl font-bold tracking-tight">Tabelas de Preço</h1>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">Parametrize os valores cobrados por período de vigência.</p>
</div>

<section class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5 shadow-sm mb-10">
    <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 mb-3">Cadastrar Nova Tabela</h2>
    <form asp-action="Cadastrar" method="post" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 items-end">
        <div>
            <label class="block text-xs font-medium text-zinc-500 dark:text-zinc-400 mb-1">Início da Vigência</label>
            <input type="date" name="dataInicioVigencia" required
                   class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition" />
        </div>
        <div>
            <label class="block text-xs font-medium text-zinc-500 dark:text-zinc-400 mb-1">Fim da Vigência</label>
            <input type="date" name="dataFimVigencia" required
                   class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition" />
        </div>
        <div>
            <label class="block text-xs font-medium text-zinc-500 dark:text-zinc-400 mb-1">Valor Hora Inicial</label>
            <input type="number" step="0.01" name="valorHoraInicial" required placeholder="0,00"
                   class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition" />
        </div>
        <div>
            <label class="block text-xs font-medium text-zinc-500 dark:text-zinc-400 mb-1">Valor Hora Adicional</label>
            <input type="number" step="0.01" name="valorHoraAdicional" required placeholder="0,00"
                   class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition" />
        </div>
        <button type="submit"
                class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 active:scale-95 text-white text-sm font-medium px-5 py-2 transition-all duration-150">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Cadastrar
        </button>
    </form>
</section>

<section>
    <h2 class="text-lg font-semibold mb-4">Tabelas cadastradas</h2>
    <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-zinc-200 dark:border-zinc-800 text-left text-xs uppercase tracking-wide text-zinc-500 dark:text-zinc-400">
                        <th class="px-4 py-3 font-medium">Início da Vigência</th>
                        <th class="px-4 py-3 font-medium">Fim da Vigência</th>
                        <th class="px-4 py-3 font-medium text-right">Valor Hora Inicial</th>
                        <th class="px-4 py-3 font-medium text-right">Valor Hora Adicional</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100 dark:divide-zinc-800">
                    @foreach (var tabela in Model)
                    {
                        <tr class="hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors">
                            <td class="px-4 py-3 text-zinc-600 dark:text-zinc-400">@tabela.DataInicioVigencia.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-3 text-zinc-600 dark:text-zinc-400">@tabela.DataFimVigencia.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-3 text-right font-medium">@tabela.ValorHoraInicial.ToString("C", new CultureInfo("pt-BR"))</td>
                            <td class="px-4 py-3 text-right font-medium">@tabela.ValorHoraAdicional.ToString("C", new CultureInfo("pt-BR"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
